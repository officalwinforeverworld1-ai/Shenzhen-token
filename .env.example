# ============================================
# Shén Zhèn Airdrop — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# === Database ===
DATABASE_URL="postgresql://shen_zhen:dev_password_change_me@localhost:5432/shen_zhen_airdrop?schema=public"

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN="your-bot-token-from-botfather"
# The channel/group users must join (use the @username or numeric chat ID)
REQUIRED_CHANNEL_ID="@your_channel"

# === Webhook ===
# Public HTTPS URL where Telegram sends webhook updates
# For dev: use ngrok, localtunnel, or similar
WEBHOOK_URL="https://your-domain.com/webhook"
# Port the bot/API server listens on
PORT=3000

# === Mini App ===
# Public URL where the Mini App is hosted
MINI_APP_URL="https://your-domain.com"

# === Admin Panel ===
# Secret for session cookies (generate a random 64-char string)
ADMIN_SESSION_SECRET="generate-a-random-secret-here-at-least-32-chars"
# Port for admin panel
ADMIN_PORT=3001

# === JWT ===
# Secret for Mini App auth tokens (different from admin session secret)
JWT_SECRET="generate-another-random-secret-here"
# Token expiry (e.g., "24h", "7d")
JWT_EXPIRY="24h"

# === First Admin User (used by seed script) ===
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-password"
